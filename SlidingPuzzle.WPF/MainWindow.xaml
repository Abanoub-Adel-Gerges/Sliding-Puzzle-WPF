<Window x:Class="SlidingPuzzle.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sliding Puzzle Master" Height="650" Width="950" 
        Icon="pack://application:,,,/Assets/Icon.ico"
        Background="#F5F7FA" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <Border Background="White" CornerRadius="15" Padding="20" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Puzzle Board" FontSize="18" FontWeight="Bold" Foreground="#2D3748" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    <Border BorderBrush="#E2E8F0" BorderThickness="2" CornerRadius="10" 
                            HorizontalAlignment="Center" VerticalAlignment="Center" Background="#EDF2F7" Padding="5">
                        <UniformGrid x:Name="PuzzleGrid" />
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>

        <Grid Grid.Column="1" Margin="25,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Configuration" FontSize="14" FontWeight="Bold" Margin="0,0,0,10" Foreground="#4A5568"/>
                    <UniformGrid Columns="3">
                        <StackPanel Margin="5,0">
                            <TextBlock Text="Dimensions" FontSize="10" Foreground="#718096"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="TxtH" Text="3" Width="35" Padding="3"/>
                                <TextBlock Text="×" Margin="1,0" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtW" Text="3" Width="35" Padding="3"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="5,0">
                            <TextBlock Text="Timeout (s)" FontSize="10" Foreground="#718096"/>
                            <TextBox x:Name="TxtTimeout" Text="5" Width="50" Padding="3" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <Button Content="Shuffle" Click="NewGame_Click" Style="{StaticResource ModernButtonStyle}" Background="#48BB78" Height="35" VerticalAlignment="Bottom"/>
                    </UniformGrid>

                    <Separator Margin="0,12" Background="#EDF2F7"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="CboAlgorithm" Padding="5" SelectedIndex="0" VerticalAlignment="Center">
                            <ComboBoxItem Content="A* Search" Tag="AStar"/>
                            <ComboBoxItem Content="Greedy Search" Tag="Greedy"/>
                            <ComboBoxItem Content="Uniform Cost (UCS)" Tag="UCS"/>
                        </ComboBox>
                        <Button Grid.Column="1" Content="Solve Auto" Click="Solve_Click" Style="{StaticResource ModernButtonStyle}" Background="#4299E1" Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,15">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Path Steps" FontSize="14" FontWeight="Bold" Margin="0,0,0,5" Foreground="#4A5568"/>
                    <ListBox x:Name="ListPath" Height="60" BorderThickness="1" BorderBrush="#E2E8F0" Background="#F8FAFC">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#EBF8FF" CornerRadius="4" Margin="2" Padding="5,2">
                                    <TextBlock Text="{Binding}" Foreground="#2B6CB0" FontWeight="Bold" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
            <Border Grid.Row="2" Background="#2D3748" CornerRadius="12" Padding="15">
                <DockPanel>
                    <Button DockPanel.Dock="Top" Content="Compare All Algorithms" Click="CompareAll_Click" 
                    Style="{StaticResource ModernButtonStyle}" Background="#805AD5" Margin="0,0,0,10"/>

                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Performance Analysis" Foreground="#A0AEC0" FontSize="11" FontWeight="Bold"/>
                        <Border Background="#4A5568" Margin="10,0,0,0" Padding="5,1" CornerRadius="3">
                            <TextBlock Text="Live Log" Foreground="White" FontSize="9"/>
                        </Border>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TxtStats" Text="Ready!" Foreground="#F7FAFC" FontSize="13" 
                           FontFamily="Consolas" TextWrapping="Wrap" LineHeight="20"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>